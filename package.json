{
  "name": "disciplr-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:perf": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=performance --maxWorkers=1",
    "test:api-keys": "tsx --test src/routes/apiKeys.test.ts",
    "test:vaults": "tsx --test src/routes/vaults.test.ts",
    "test:vault-validation": "node --experimental-vm-modules node_modules/jest/bin/jest.js src/services/vaultValidation.test.ts",
    "test:vaults-integration": "tsx --test src/routes/vaults.test.ts",
    "test:smoke": "tsx --test src/tests/smoke/api.smoke.test.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.cjs --migrations-directory db/migrations --extension cjs",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.cjs",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.cjs",
    "migrate:status": "knex migrate:status --knexfile knexfile.cjs",
    "openapi:generate": "tsx src/docs/generate-spec.ts",
    "openapi:lint": "redocly lint docs/openapi.yaml",
    "openapi:validate": "redocly stats docs/openapi.yaml"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/lib-storage": "^3.1058.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@prisma/client": "^6.19.2",
    "@stellar/stellar-sdk": "^14.5.0",
    "argon2": "^0.31.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^9.4.0",
    "prom-client": "^15.0.0",
    "zod": "^4.3.6",
    "argon2": "^0.44.0",
    "graphql": "^16.8.1",
    "graphql-http": "^1.22.0",
    "graphql-depth-limit": "^1.1.0",
    "dataloader": "^2.2.2"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@eslint/js": "^9.13.0",
    "@redocly/cli": "^2.29.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/graphql-depth-limit": "^1.1.4",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.13.0",
    "fast-check": "^3.23.1",
    "jest": "^29.7.0",
    "knex": "^3.1.0",
    "mime": "^2.6.0",
    "pino-pretty": "^10.3.1",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.3"
  }
}
